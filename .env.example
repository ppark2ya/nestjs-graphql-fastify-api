# ================================================================
# 환경변수 템플릿 (Portainer Stack 배포용)
# 이 파일을 .env로 복사하여 실제 값을 설정하세요
# ================================================================

# Docker Image
DOCKER_REPO_GATEWAY=ppark2ya/nestjs-gateway
DOCKER_REPO_AUTH=ppark2ya/nestjs-auth
TAG=latest

# Database (외부 관리)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USERNAME=your-user
DB_PASSWORD=your-password
DB_DATABASE=auth_db

# JWT Keys
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key

# UI
VITE_API_KEY=test-api-key
# Set to LOTTE_CARD_BO for Lotte Card UI builds.
VITE_AUTH_USER_TYPE=ADMIN_BO

# Kiosk Admin
KIOSK_ADMIN_URL=your-kiosk-admin-url
